# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3001/api

# AWS Configuration
VITE_AWS_REGION=us-east-1
VITE_AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com

# Analytics Dashboard
VITE_DASHBOARD_REFRESH_INTERVAL=5000

# Feature Flags
VITE_ENABLE_REAL_TIME_ALERTS=true
VITE_ENABLE_SMTP_ALERTS=true
